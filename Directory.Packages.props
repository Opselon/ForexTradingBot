<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
    <CentralPackageTransitivePinningEnabled>true</CentralPackageTransitivePinningEnabled>
  </PropertyGroup>

  <ItemGroup>
    <!-- Microsoft Packages -->
    <PackageVersion Include="Microsoft.AspNetCore.OpenApi" Version="9.0.0-preview.5.24306.11" />
    <PackageVersion Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="9.0.0-preview.5.24306.11" />
    <PackageVersion Include="Microsoft.Data.SqlClient" Version="5.2.0" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore" Version="9.0.0-preview.5.24306.3" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore.Design" Version="9.0.0-preview.5.24306.3" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore.Relational" Version="9.0.0-preview.5.24306.3" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore.SqlServer" Version="9.0.0-preview.5.24306.3" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore.Sqlite" Version="9.0.0-preview.5.24306.3" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore.Tools" Version="9.0.0-preview.5.24306.3" />
    <PackageVersion Include="Microsoft.Extensions.Configuration" Version="9.0.0" /> <!-- Updated from preview -->
    <PackageVersion Include="Microsoft.Extensions.Configuration.Abstractions" Version="9.0.0" /> <!-- Updated from preview -->
    <PackageVersion Include="Microsoft.Extensions.Configuration.Binder" Version="9.0.0" />     <!-- Updated from preview -->
    <PackageVersion Include="Microsoft.Extensions.DependencyInjection" Version="9.0.0-preview.5.24306.7" /> <!-- Keep this preview unless Serilog also forces 9.0.0 final -->
    <PackageVersion Include="Microsoft.Extensions.Hosting" Version="9.0.0-preview.5.24306.7" />         <!-- Keep this preview unless Hangfire->Hosting.Abstractions 9.0.0 forces final 9.0.0 -->
    <PackageVersion Include="Microsoft.Extensions.Hosting.Abstractions" Version="9.0.0" />  <!-- Forced by Hangfire.NetCore / Hosting.Abstractions 9.0.0 in log -->
    <PackageVersion Include="Microsoft.Extensions.Http" Version="9.0.0-preview.5.24306.7" />
    <PackageVersion Include="Microsoft.Extensions.Http.Polly" Version="9.0.0-preview.5.24306.11" />
    <PackageVersion Include="Microsoft.Extensions.Logging" Version="9.0.0" />         <!-- Updated from preview -->
    <PackageVersion Include="System.Net.Http.Json" Version="9.0.0-preview.5.24306.7" />
    <PackageVersion Include="System.ServiceModel.Syndication" Version="9.0.0-preview.5.24306.7" />
    <PackageVersion Include="System.Threading.Channels" Version="9.0.0-preview.5.24306.7" />

    <!-- Hangfire Packages - Unified to 1.8.20 -->
    <PackageVersion Include="Hangfire" Version="1.8.20" />
    <PackageVersion Include="Hangfire.AspNetCore" Version="1.8.20" />
    <PackageVersion Include="Hangfire.Core" Version="1.8.20" />
    <PackageVersion Include="Hangfire.NetCore" Version="1.8.20" />
    <PackageVersion Include="Hangfire.PostgreSql" Version="1.20.8" />
    <PackageVersion Include="Hangfire.SqlServer" Version="1.8.20" />
    <PackageVersion Include="Hangfire.MemoryStorage" Version="1.8.1.1" />

    <!-- Other Packages (نسخه‌های قبلی شما که مشکل واضح نداشتند یا نسخه‌های معتبر شده) -->
    <PackageVersion Include="AutoMapper" Version="14.0.0" />
    <PackageVersion Include="Dapper" Version="2.1.66" />
    <PackageVersion Include="FluentSpecification.Abstractions" Version="1.3.0" />
    <PackageVersion Include="FluentValidation" Version="11.9.2" />
    <PackageVersion Include="FluentValidation.DependencyInjectionExtensions" Version="11.9.2" />
    <PackageVersion Include="HtmlAgilityPack" Version="1.11.61" />
    <PackageVersion Include="MediatR" Version="12.5.0" />
    <PackageVersion Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="9.0.0-preview.7" />
    <PackageVersion Include="Polly" Version="8.5.2" />
    <PackageVersion Include="Polly.Core" Version="8.5.2" />
    <PackageVersion Include="Quartz" Version="3.14.0" />
    <PackageVersion Include="RestSharp" Version="112.1.0" />
    <PackageVersion Include="Scrutor" Version="4.2.2" /> <!-- این در فایل cat شده Directory.Packages.props بود، شما در csproj 6.0.1 داشتید -->
    <PackageVersion Include="Serilog.AspNetCore" Version="9.0.0" /> <!-- شما این را دارید، و این نیاز به نسخه نهایی Extensions دارد -->
    <PackageVersion Include="Swashbuckle.AspNetCore" Version="6.6.2" />
    <PackageVersion Include="Telegram.Bot" Version="22.5.1" />
    <PackageVersion Include="WTelegramClient" Version="4.3.4" />
  </ItemGroup>
</Project>