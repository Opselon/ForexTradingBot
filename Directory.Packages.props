    <!-- Infrastructure.csproj References (پکیج‌های جدید یا متفاوت) -->
    <PackageVersion Include="HtmlAgilityPack" Version="1.12.1" /> <!-- بسیار قدیمی، آخرین پایدار ~1.11.61 -->
