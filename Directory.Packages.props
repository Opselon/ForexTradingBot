    <PackageVersion Include="Microsoft.Extensions.Logging" Version="9.0.0-preview.5.24306.7" />
    <PackageVersion Include="System.Net.Http.Json" Version="9.0.0-preview.5.24306.7" />
    <PackageVersion Include="System.ServiceModel.Syndication" Version="9.0.0-preview.5.24306.7" />
    <PackageVersion Include="System.Threading.Channels" Version="9.0.0-preview.5.24306.7" />
  
    <!-- WebAPI.csproj References -->
    <PackageVersion Include="FluentValidation" Version="12.0.0" /> <!-- هشدار: این نسخه احتمالاً صحیح نیست، 11.9.2 پایدار است -->
 <PackageVersion Include="Hangfire.AspNetCore" Version="1.8.12" /> 
    <PackageVersion Include="Hangfire" Version="1.8.20" />
    <PackageVersion Include="Hangfire.AspNetCore" Version="1.8.20" />
    <PackageVersion Include="Hangfire.Core" Version="1.8.20" />
    <PackageVersion Include="Hangfire.NetCore" Version="1.8.20" />
    <PackageVersion Include="Hangfire.PostgreSql" Version="1.20.8" /> <!-- این نسخه خودش را دارد -->
    <PackageVersion Include="Hangfire.SqlServer" Version="1.8.20" />
    <PackageVersion Include="Hangfire.MemoryStorage" Version="1.8.1.1" /> <!-- این نسخه خودش را دارد -->
	
	
    <PackageVersion Include="MediatR" Version="12.5.0" /> <!-- بسیار جدید، پایدارتر 12.3.0 -->
    <PackageVersion Include="Microsoft.AspNetCore.OpenApi" Version="9.0.4" /> <!-- نسخه preview نامشخص -->
    <PackageVersion Include="Microsoft.EntityFrameworkCore.Design" Version="9.0.5" /> <!-- نسخه preview نامشخص، احتمالاً باید 9.0.0-preview.X باشد -->
    <PackageVersion Include="Microsoft.Extensions.Http.Polly" Version="9.0.5" /> <!-- نسخه preview نامشخص -->
   <PackageVersion Include="Serilog.AspNetCore" Version="8.0.1" /> <!-- نسخه پایدار سازگار -->
     <PackageVersion Include="Swashbuckle.AspNetCore" Version="6.6.2" /> <!-- نسخه پایدار -->
    <!-- Telegram.Bot از WebAPI و TelegramPanel و BackgroundTasks، بالاترین نسخه را در نظر می‌گیریم -->
    <PackageVersion Include="Telegram.Bot" Version="22.5.1" /> <!-- بسیار جدید، احتمالاً preview یا فورک -->

    <!-- Application.csproj References (پکیج‌های جدید یا متفاوت با WebAPI) -->
