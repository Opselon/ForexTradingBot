    <!-- Otherwise, stick to consistent preview like ...24306.7 or the very latest preview available. -->
    <PackageVersion Include="Microsoft.Extensions.Configuration" Version="9.0.0-preview.5.24306.7" />
    <PackageVersion Include="Microsoft.Extensions.Configuration.Abstractions" Version="9.0.0-preview.5.24306.7" />
